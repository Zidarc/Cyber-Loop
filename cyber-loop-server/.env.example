# Server
PORT=3000

# Database
DB_FILE_PATH=./data/database.sqlite

# Authentication
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# File uploads
UPLOAD_DIR=./uploads

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase
SUPUBASE_PROJECT_URL=https://your-project-id.supabase.co
SUPABASE_PUBLIC_KEY=your_public_key_here
SUPABASE_ANON_KEY=your_anon_key_here