# Server
PORT=3000

# Database
DB_FILE_PATH=./data/database.sqlite

# Authentication
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# File uploads
UPLOAD_DIR=./uploads

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase
SUPUBASE_PROJECT_URL=https://your-project-id.supabase.co
SUPABASE_PUBLIC_KEY=your_public_key_here
SUPABASE_ANON_KEY=your_anon_key_here


# Game graph config
GAME_START_NODE_ID=1
GAME_FINAL_NODE_ID=7

# Checkpoints on the main path (IDs from your Supabase `nodes` table)
GAME_CHECKPOINT_NODE_IDS=1,4

# How many penalty nodes exist for the game design
GAME_PENALTY_NODE_COUNT=5

# Optional: explicit penalty node IDs (if you want a fixed order)
# e.g. if your penalty nodes are ids 8–12 in `nodes`
GAME_PENALTY_NODE_IDS=8,9,10,11,12